<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="concrete_polymorphic_targets" nsURI="http://www.example.org/concrete_polymorphic_targets" nsPrefix="concrete_polymorphic_targets">
    <eClassifiers xsi:type="ecore:EClass" name="A">
        <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" lowerBound="1" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="B" eSuperTypes="#//A">
        <eStructuralFeatures xsi:type="ecore:EAttribute" name="bflag" lowerBound="1" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="C" eSuperTypes="#//B">
        <eStructuralFeatures xsi:type="ecore:EAttribute" name="cflag" lowerBound="1" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="D">
        <eStructuralFeatures xsi:type="ecore:EReference" name="child" eType="#//A" containment="true"/>
        <eStructuralFeatures xsi:type="ecore:EReference" name="target" eType="#//A"/>
    </eClassifiers>
</ecore:EPackage>
